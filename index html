<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Sistema Financeiro</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<style>
body { font-family: Arial; margin: 20px; }
input, select, button { margin: 5px; }
.card { border: 1px solid #ccc; padding: 10px; margin: 10px 0; }
nav button { margin-right: 10px; }
section { display: none; }
section.active { display: block; }
</style>
</head>
<body>

<h1>💰 Sistema Financeiro</h1>

<nav>
  <button onclick="abrirTela('cadastro')">Cadastro</button>
  <button onclick="abrirTela('movimentacao')">Movimentação</button>
  <button onclick="abrirTela('saldo')">Saldo</button>
</nav>

<!-- 1️⃣ Tela Cadastro -->
<section id="cadastro">
<h2>👤 Cadastro de Cliente</h2>
<input id="nome" placeholder="Nome">
<input id="cpf" placeholder="CPF/CNPJ">
<button onclick="cadastrarCliente()">Cadastrar</button>

<h3>Clientes Cadastrados</h3>
<div id="listaClientes"></div>
</section>

<!-- 2️⃣ Tela Movimentação -->
<section id="movimentacao">
<h2>💸 Movimentação</h2>
<select id="clienteSelect"></select>
<select id="tipo">
  <option value="entrada">Entrada</option>
  <option value="saida">Saída</option>
</select>
<input id="valor" placeholder="Valor">
<input id="origem" placeholder="Origem">
<button onclick="movimentar()">Salvar</button>

<h3>Histórico</h3>
<div id="historico"></div>
</section>

<!-- 3️⃣ Tela Saldo -->
<section id="saldo">
<h2>📊 Saldo por Cliente</h2>
<div id="saldos"></div>
<button onclick="gerarPDF()">📄 Gerar PDF</button>
</section>

<script>
// Dados
let clientes = JSON.parse(localStorage.getItem("clientes")) || [];
let movs = JSON.parse(localStorage.getItem("movs")) || [];

// Troca de telas
function abrirTela(id){
  document.querySelectorAll("section").forEach(s => s.classList.remove("active"));
  document.getElementById(id).classList.add("active");
  atualizarTela();
}

// Salvar no LocalStorage
function salvar(){
  localStorage.setItem("clientes", JSON.stringify(clientes));
  localStorage.setItem("movs", JSON.stringify(movs));
}

// Cadastro
function cadastrarCliente(){
  let nome = document.getElementById("nome").value;
  let cpf = document.getElementById("cpf").value;
  if(!nome || !cpf){ alert("Preencha todos os campos"); return; }
  clientes.push({id: Date.now(), nome, cpf});
  salvar();
  document.getElementById("nome").value = "";
  document.getElementById("cpf").value = "";
  atualizarTela();
}

function excluirCliente(id){
  clientes = clientes.filter(c => c.id !== id);
  movs = movs.filter(m => m.cliente_id !== id);
  salvar();
  atualizarTela();
}

// Movimentação
function movimentar(){
  let cliente_id = parseInt(document.getElementById("clienteSelect").value);
  let tipo = document.getElementById("tipo").value;
  let valor = parseFloat(document.getElementById("valor").value);
  let origem = document.getElementById("origem").value;
  if(!valor || !origem){ alert("Preencha todos os campos"); return; }
  movs.push({id: Date.now(), cliente_id, tipo, valor, origem, data: new Date().toLocaleString()});
  document.getElementById("valor").value = "";
  document.getElementById("origem").value = "";
  salvar();
  atualizarTela();
}

// Saldo
function calcularSaldo(cliente_id){
  return movs.filter(m => m.cliente_id===cliente_id)
             .reduce((s,m)=> s + (m.tipo==='entrada'? m.valor : -m.valor), 0);
}

// Atualizar telas
function atualizarTela(){
  // Lista clientes
  let lista = document.getElementById("listaClientes");
  let select = document.getElementById("clienteSelect");
  let historico = document.getElementById("historico");
  let saldosDiv = document.getElementById("saldos");

  lista.innerHTML = "";
  select.innerHTML = "";
  historico.innerHTML = "";
  saldosDiv.innerHTML = "";

  clientes.forEach(c=>{
    // Cadastro
    lista.innerHTML += `<div class="card">${c.nome} - ${c.cpf} 
      <button onclick="excluirCliente(${c.id})">Excluir</button></div>`;

    // Movimentação
    select.innerHTML += `<option value="${c.id}">${c.nome}</option>`;

    // Histórico
    let hist = movs.filter(m=>m.cliente_id===c.id);
    hist.forEach(m=>{
      historico.innerHTML += `<div class="card">
        ${m.data} - ${m.tipo} - R$ ${m.valor.toFixed(2)} - ${m.origem}</div>`;
    });

    // Saldo
    let saldo = calcularSaldo(c.id);
    saldosDiv.innerHTML += `<div class="card">${c.nome} → Saldo: R$ ${saldo.toFixed(2)}</div>`;
  });
}

// PDF
function gerarPDF(){
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF();
  doc.setFontSize(16);
  doc.text("📊 Saldo por Cliente", 10, 20);
  let y = 30;
  clientes.forEach(c=>{
    let saldo = calcularSaldo(c.id).toFixed(2);
    doc.setFontSize(12);
    doc.text(`${c.nome} (${c.cpf}) → R$ ${saldo}`, 10, y);
    y += 10;
  });
  doc.save("saldo_clientes.pdf");
  alert("PDF gerado! Você pode enviar pelo WhatsApp.");
}

// Inicializa primeira tela
abrirTela('cadastro');
</script>

</body>
</html>
